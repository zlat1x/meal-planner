@model IEnumerable<MealPlanner.Domain.Entities.ShopList>

@{
    ViewData["Title"] = "Списки покупок";
    var items = Model.ToList();
}

<div class="page-hero">
    <div class="page-title-wrap">
        <h1>Списки покупок</h1>
        <p class="page-subtitle">
            Списки покупок, сформовані на основі планів харчування користувачів.
        </p>
    </div>

    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Створити список</a>
    </div>
</div>

<div class="summary-grid">
    <div class="summary-card">
        <div class="summary-card-title">Усього списків</div>
        <div class="summary-card-value">@items.Count</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Пов’язаних планів</div>
        <div class="summary-card-value">@items.Select(x => x.PlanId).Distinct().Count()</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Макс. кількість днів</div>
        <div class="summary-card-value">@(items.Any() ? items.Max(x => x.Days) : 0)</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Останнє створення</div>
        <div class="summary-card-value">@(items.Any() ? items.Max(x => x.CreatedAt).ToString("dd.MM") : "-")</div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (items.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Користувач</th>
                            <th>План</th>
                            <th>Днів</th>
                            <th>Створено</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>@item.Plan.User.Name</td>
                            <td>@item.Plan.Status</td>
                            <td>@item.Days</td>
                            <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Деталі</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="empty-state">Списків покупок ще немає.</p>
        }
    </div>
</div>