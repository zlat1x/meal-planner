@model MealPlanner.Domain.Entities.ShopList

@{
    ViewData["Title"] = "Shop list details";
}

<h1>Shop list details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Plan user</dt>
        <dd class="col-sm-10">@Model.Plan.User.Name</dd>

        <dt class="col-sm-2">Plan status</dt>
        <dd class="col-sm-10">@Model.Plan.Status</dd>

        <dt class="col-sm-2">Days</dt>
        <dd class="col-sm-10">@Model.Days</dd>

        <dt class="col-sm-2">Created at</dt>
        <dd class="col-sm-10">@Model.CreatedAt</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</div>