@model MealPlanner.Domain.Entities.ShopList

@{
    ViewData["Title"] = "Delete shop list";
}

<h1>Delete shop list</h1>

<h3>Are you sure you want to delete this shop list?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Plan user</dt>
        <dd class="col-sm-10">@Model.Plan.User.Name</dd>

        <dt class="col-sm-2">Days</dt>
        <dd class="col-sm-10">@Model.Days</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to list</a>
    </form>
</div>