@model IEnumerable<MealPlanner.Domain.Entities.ShopItem>

@{
    ViewData["Title"] = "Shop items";
}

<h1>Shop items</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create new shop item</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Shop list</th>
            <th>Food</th>
            <th>Total quantity</th>
            <th>Quantity unit</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.List.Id</td>
            <td>@item.Food.Name</td>
            <td>@item.TotalQuantityValue</td>
            <td>@item.QuantityUnit.Name</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>