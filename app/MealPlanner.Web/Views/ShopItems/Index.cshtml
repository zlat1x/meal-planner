@model IEnumerable<MealPlanner.Domain.Entities.ShopItem>

@{
    ViewData["Title"] = "Позиції списку покупок";
    var items = Model.ToList();
}

<div class="page-hero">
    <div class="page-title-wrap">
        <h1>Позиції списку покупок</h1>
        <p class="page-subtitle">Товари та кількість у сформованих списках покупок.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Додати позицію</a>
    </div>
</div>

<div class="summary-grid">
    <div class="summary-card">
        <div class="summary-card-title">Усього позицій</div>
        <div class="summary-card-value">@items.Count</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Списків</div>
        <div class="summary-card-value">@items.Select(x => x.ListId).Distinct().Count()</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Продуктів</div>
        <div class="summary-card-value">@items.Select(x => x.FoodId).Distinct().Count()</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Одиниць</div>
        <div class="summary-card-value">@items.Select(x => x.QuantityUnitId).Distinct().Count()</div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (items.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Продукт</th>
                            <th>Список</th>
                            <th>Кількість</th>
                            <th>Одиниця</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>@item.Food.Name</td>
                            <td>@item.List.Id</td>
                            <td>@item.TotalQuantityValue</td>
                            <td>@item.QuantityUnit.Name</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Деталі</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="empty-state">Позицій списку покупок ще немає.</p>
        }
    </div>
</div>