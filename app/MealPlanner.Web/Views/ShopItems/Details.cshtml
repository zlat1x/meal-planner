@model MealPlanner.Domain.Entities.ShopItem

@{
    ViewData["Title"] = "Shop item details";
}

<h1>Shop item details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Shop list</dt>
        <dd class="col-sm-10">@Model.List.Id</dd>

        <dt class="col-sm-2">Food</dt>
        <dd class="col-sm-10">@Model.Food.Name</dd>

        <dt class="col-sm-2">Total quantity</dt>
        <dd class="col-sm-10">@Model.TotalQuantityValue</dd>

        <dt class="col-sm-2">Quantity unit</dt>
        <dd class="col-sm-10">@Model.QuantityUnit.Name</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</div>