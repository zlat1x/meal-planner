@model MealPlanner.Domain.Entities.ShopItem

@{
    ViewData["Title"] = "Create shop item";
}

<h1>Create shop item</h1>

<hr />

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="ListId" class="form-label">Shop list</label>
                <select asp-for="ListId" asp-items="ViewBag.ListId" class="form-select">
                    <option value="">Select shop list</option>
                </select>
                <span asp-validation-for="ListId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FoodId" class="form-label">Food</label>
                <select asp-for="FoodId" asp-items="ViewBag.FoodId" class="form-select">
                    <option value="">Select food</option>
                </select>
                <span asp-validation-for="FoodId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TotalQuantityValue" class="form-label"></label>
                <input asp-for="TotalQuantityValue" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="QuantityUnitId" class="form-label">Quantity unit</label>
                <select asp-for="QuantityUnitId" asp-items="ViewBag.QuantityUnitId" class="form-select">
                    <option value="">Select quantity unit</option>
                </select>
                <span asp-validation-for="QuantityUnitId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to list</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}