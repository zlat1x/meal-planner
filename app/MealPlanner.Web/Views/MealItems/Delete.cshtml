@model MealPlanner.Domain.Entities.MealItem

@{
    ViewData["Title"] = "Delete meal item";
}

<h1>Delete meal item</h1>

<h3>Are you sure you want to delete this meal item?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Meal</dt>
        <dd class="col-sm-10">@Model.Meal.Name</dd>

        <dt class="col-sm-2">Food</dt>
        <dd class="col-sm-10">@Model.Food.Name</dd>

        <dt class="col-sm-2">Quantity</dt>
        <dd class="col-sm-10">@Model.QuantityValue</dd>

        <dt class="col-sm-2">Quantity unit</dt>
        <dd class="col-sm-10">@Model.QuantityUnit.Name</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to list</a>
    </form>
</div>