@model IEnumerable<MealPlanner.Domain.Entities.Configuration>

@{
    ViewData["Title"] = "Configurations";
}

<h1>Configurations</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create new configuration</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>User</th>
            <th>Language</th>
            <th>Meals per day</th>
            <th>Active macro</th>
            <th>Updated at</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.User.Name</td>
            <td>@item.Lang</td>
            <td>@item.MealsPerDay</td>
            <td>@(item.ActiveMacro != null ? item.ActiveMacro.Mode : "-")</td>
            <td>@item.UpdatedAt</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.UserId">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.UserId">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.UserId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>