@{
    ViewData["Title"] = "Meal Planner";
}

<div class="text-center">
    <h1 class="display-4">Meal Planner</h1>
    <p>ASP.NET Core MVC application for meal planning and nutrition management.</p>
</div>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <p class="card-text">Manage application users.</p>
                <a asp-controller="Users" asp-action="Index" class="btn btn-primary">Open users</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Units</h5>
                <p class="card-text">Manage measurement units.</p>
                <a asp-controller="Units" asp-action="Index" class="btn btn-primary">Open units</a>
            </div>
        </div>
    </div>
</div>