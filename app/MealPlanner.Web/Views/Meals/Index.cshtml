@model IEnumerable<MealPlanner.Domain.Entities.Meal>

@{
    ViewData["Title"] = "Прийоми їжі";
    var items = Model.ToList();
}

<div class="page-hero">
    <div class="page-title-wrap">
        <h1>Прийоми їжі</h1>
        <p class="page-subtitle">Структура планів харчування по днях і прийомах їжі.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Додати прийом їжі</a>
    </div>
</div>

<div class="summary-grid">
    <div class="summary-card">
        <div class="summary-card-title">Усього прийомів</div>
        <div class="summary-card-value">@items.Count</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Планів</div>
        <div class="summary-card-value">@items.Select(x => x.PlanId).Distinct().Count()</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Днів</div>
        <div class="summary-card-value">@items.Select(x => x.DayNo).Distinct().Count()</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Назв</div>
        <div class="summary-card-value">@items.Select(x => x.Name).Distinct().Count()</div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (items.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Користувач</th>
                            <th>День</th>
                            <th>Прийом</th>
                            <th>Назва</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>@item.Plan.User.Name</td>
                            <td>@item.DayNo</td>
                            <td>@item.MealNo</td>
                            <td>@item.Name</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Деталі</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="empty-state">Прийомів їжі ще немає.</p>
        }
    </div>
</div>