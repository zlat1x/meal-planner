@model MealPlanner.Domain.Entities.Food

@{
    ViewData["Title"] = "Видалити продукт";
}

<h1>Видалити продукт</h1>
<p class="page-subtitle mb-4 text-danger">
    Підтвердь видалення продукту. Цю дію не можна легко скасувати.
</p>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Назва</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Користувач</dt>
            <dd class="col-sm-9">@Model.User.Name</dd>

            <dt class="col-sm-3">Ккал</dt>
            <dd class="col-sm-9">@Model.KcalPer100</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-danger">Видалити</button>
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>