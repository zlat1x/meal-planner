@model IEnumerable<MealPlanner.Domain.Entities.Food>

@{
    ViewData["Title"] = "Продукти";
    var items = Model.ToList();
}

<div class="page-hero">
    <div class="page-title-wrap">
        <h1>База продуктів</h1>
        <p class="page-subtitle">Службова база продуктів для конструктора меню та керування каталогом.</p>
    </div>

    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Додати продукт</a>
    </div>
</div>

<div class="summary-grid">
    <div class="summary-card">
        <div class="summary-card-title">Усього продуктів</div>
        <div class="summary-card-value">@items.Count</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Користувацькі</div>
        <div class="summary-card-value">@items.Count(x => x.IsCustom)</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Базові</div>
        <div class="summary-card-value">@items.Count(x => !x.IsCustom)</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">З іконкою</div>
        <div class="summary-card-value">@items.Count(x => x.IconId.HasValue)</div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (items.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Продукт</th>
                            <th>Користувач</th>
                            <th>Білки</th>
                            <th>Вуглеводи</th>
                            <th>Жири</th>
                            <th>Ккал</th>
                            <th>Одиниця</th>
                            <th>Тип</th>
                            <th>Оновлено</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>
                                <span class="inline-emoji">@(item.Icon?.Emoji ?? "🍽️")</span>
                                @item.Name
                            </td>
                            <td>@item.User.Name</td>
                            <td>@item.ProteinPer100</td>
                            <td>@item.CarbsPer100</td>
                            <td>@item.FatPer100</td>
                            <td>@item.KcalPer100</td>
                            <td>@item.Per100Unit.Name</td>
                            <td>
                                @if (item.IsCustom)
                                {
                                    <span class="status-badge status-green">Користувацький</span>
                                }
                                else
                                {
                                    <span class="status-badge status-blue">Базовий</span>
                                }
                            </td>
                            <td>@item.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Деталі</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="empty-state">Продукти ще не додані.</p>
        }
    </div>
</div>