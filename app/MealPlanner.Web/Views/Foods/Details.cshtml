@model MealPlanner.Domain.Entities.Food

@{
    ViewData["Title"] = "Деталі продукту";
}

<h1>Деталі продукту</h1>
<p class="page-subtitle mb-4">Повна інформація про вибраний продукт.</p>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Назва</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Користувач</dt>
            <dd class="col-sm-9">@Model.User.Name</dd>

            <dt class="col-sm-3">Іконка</dt>
            <dd class="col-sm-9">@(Model.Icon?.Emoji ?? "—")</dd>

            <dt class="col-sm-3">Одиниця</dt>
            <dd class="col-sm-9">@Model.Per100Unit.Name</dd>

            <dt class="col-sm-3">Білки</dt>
            <dd class="col-sm-9">@Model.ProteinPer100</dd>

            <dt class="col-sm-3">Вуглеводи</dt>
            <dd class="col-sm-9">@Model.CarbsPer100</dd>

            <dt class="col-sm-3">Жири</dt>
            <dd class="col-sm-9">@Model.FatPer100</dd>

            <dt class="col-sm-3">Ккал</dt>
            <dd class="col-sm-9">@Model.KcalPer100</dd>

            <dt class="col-sm-3">Тип</dt>
            <dd class="col-sm-9">@(Model.IsCustom ? "Користувацький" : "Базовий")</dd>

            <dt class="col-sm-3">Оновлено</dt>
            <dd class="col-sm-9">@Model.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
        </dl>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редагувати</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>