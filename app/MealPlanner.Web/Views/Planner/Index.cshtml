@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Text.Json
@model MealPlanner.Web.Models.PlannerPageViewModel

@{
    ViewData["Title"] = "Конструктор меню";
}

<div class="planner-page" data-planner-root>
    <div class="planner-hero mb-4">
        <div class="planner-hero-content">
            <span class="info-badge">Meal Planner</span>
            <h1 class="display-5 mb-3">Конструктор меню</h1>
            <p class="planner-hero-text">
                Склади свій раціон під ціль БЖВ, обери 2, 3 або 4 прийоми їжі
                та отримай готовий список продуктів і покупок.
            </p>
        </div>
    </div>

    @if (ViewBag.PlannerSuccess != null)
    {
        <div class="alert alert-success mb-4">
            @ViewBag.PlannerSuccess
        </div>
    }

    @if (ViewBag.ImportSuccess != null)
    {
        <div class="alert alert-info mb-4">
            @ViewBag.ImportSuccess
        </div>
    }

    <div class="card planner-main-card mb-4">
        <div class="card-body">
            <form asp-controller="Planner" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input asp-for="MealsPerDay" type="hidden" id="MealsPerDay" />

                <div class="planner-config-wrap mb-4">
                    <div class="planner-config-left">
                        <div class="planner-config-card">
                            <div class="planner-config-title">Кількість прийомів</div>

                            <div class="meal-count-switch">
                                <button type="button" class="meal-count-btn" data-meal-count="2">2 прийоми</button>
                                <button type="button" class="meal-count-btn" data-meal-count="3">3 прийоми</button>
                                <button type="button" class="meal-count-btn" data-meal-count="4">4 прийоми</button>
                            </div>
                        </div>
                    </div>

                    <div class="planner-config-right">
                        <div class="planner-config-card planner-config-card-action">
                            <div class="planner-config-title">Мої цілі</div>

                            <button type="submit" asp-action="LoadDefaults" class="btn btn-outline-primary w-100">
                                Підтягнути мої цілі БЖВ
                            </button>
                        </div>
                    </div>
                </div>

                <div class="planner-target-card mb-4">
                    <div class="section-header mb-3">
                        <h3 class="mb-0">Твоя ціль (БЖВ)</h3>
                        <span class="planner-section-note">На 1 день</span>
                    </div>

                    <div class="planner-macro-grid">
                        <div class="planner-macro-box planner-macro-box-protein">
                            <label asp-for="ProteinTarget" class="form-label">Білки</label>
                            <input asp-for="ProteinTarget" class="form-control planner-macro-input" />
                            <span asp-validation-for="ProteinTarget" class="text-danger"></span>
                        </div>

                        <div class="planner-macro-box planner-macro-box-fat">
                            <label asp-for="FatTarget" class="form-label">Жири</label>
                            <input asp-for="FatTarget" class="form-control planner-macro-input" />
                            <span asp-validation-for="FatTarget" class="text-danger"></span>
                        </div>

                        <div class="planner-macro-box planner-macro-box-carb">
                            <label asp-for="CarbTarget" class="form-label">Вуглеводи</label>
                            <input asp-for="CarbTarget" class="form-control planner-macro-input" />
                            <span asp-validation-for="CarbTarget" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="section-header mb-3">
                    <h2 class="mb-0">Прийоми їжі</h2>
                    <span class="planner-section-note">Обери продукти для кожного прийому</span>
                </div>

                <div class="planner-meals-grid">
                    @for (var i = 0; i < Model.Meals.Count; i++)
                    {
                        var selectedProtein = Model.Meals[i].ProteinFoodId.HasValue
                            ? Model.ProteinFoods.FirstOrDefault(x => x.Id == Model.Meals[i].ProteinFoodId.Value)
                            : null;

                        var selectedCarb = Model.Meals[i].CarbFoodId.HasValue
                            ? Model.CarbFoods.FirstOrDefault(x => x.Id == Model.Meals[i].CarbFoodId.Value)
                            : null;

                        var selectedFat = Model.Meals[i].FatFoodId.HasValue
                            ? Model.FatFoods.FirstOrDefault(x => x.Id == Model.Meals[i].FatFoodId.Value)
                            : null;

                        <div class="planner-meal-shell" data-meal-card data-meal-no="@Model.Meals[i].MealNo">
                            <div class="card planner-meal-card h-100">
                                <div class="card-body">
                                    <input asp-for="Meals[@i].MealNo" type="hidden" />

                                    <div class="section-header mb-3">
                                        <h3 class="mb-0">Прийом @Model.Meals[i].MealNo</h3>
                                        <span class="status-badge status-blue">Меню</span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Meals[@i].MealName" class="form-label">Назва прийому</label>
                                        <input asp-for="Meals[@i].MealName" class="form-control" />
                                        <span asp-validation-for="Meals[@i].MealName" class="text-danger"></span>
                                    </div>

                                    <div class="planner-food-role-grid">
                                        <div class="planner-food-role-box">
                                            <div class="planner-food-role-title">Білковий продукт</div>

                                            <input asp-for="Meals[@i].ProteinFoodId" type="hidden" id="proteinInput_@i" />

                                            <button type="button"
                                                    class="planner-picker-btn"
                                                    data-picker-open="protein"
                                                    data-target-input="proteinInput_@i"
                                                    data-target-label="proteinLabel_@i">
                                                <span id="proteinLabel_@i">
                                                    @(selectedProtein != null
                                                        ? $"{selectedProtein.Emoji} {selectedProtein.Name}"
                                                        : "Не вибрано")
                                                </span>
                                            </button>
                                        </div>

                                        <div class="planner-food-role-box">
                                            <div class="planner-food-role-title">Вуглеводний продукт</div>

                                            <input asp-for="Meals[@i].CarbFoodId" type="hidden" id="carbInput_@i" />

                                            <button type="button"
                                                    class="planner-picker-btn planner-picker-btn-carb"
                                                    data-picker-open="carb"
                                                    data-target-input="carbInput_@i"
                                                    data-target-label="carbLabel_@i">
                                                <span id="carbLabel_@i">
                                                    @(selectedCarb != null
                                                        ? $"{selectedCarb.Emoji} {selectedCarb.Name}"
                                                        : "Не вибрано")
                                                </span>
                                            </button>
                                        </div>

                                        <div class="planner-food-role-box">
                                            <div class="planner-food-role-title">Жировий продукт</div>

                                            <input asp-for="Meals[@i].FatFoodId" type="hidden" id="fatInput_@i" />

                                            <button type="button"
                                                    class="planner-picker-btn planner-picker-btn-fat"
                                                    data-picker-open="fat"
                                                    data-target-input="fatInput_@i"
                                                    data-target-label="fatLabel_@i">
                                                <span id="fatLabel_@i">
                                                    @(selectedFat != null
                                                        ? $"{selectedFat.Emoji} {selectedFat.Name}"
                                                        : "Не вибрано")
                                                </span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="planner-action-panel mt-4">
                    <div class="planner-days-box">
                        <label asp-for="Days" class="form-label">Список покупок на</label>
                        <select asp-for="Days" class="form-select">
                            <option value="1">1 день</option>
                            <option value="3">3 дні</option>
                            <option value="5">5 днів</option>
                            <option value="7">7 днів</option>
                        </select>
                    </div>

                    <div class="planner-action-buttons">
                        <button type="submit" asp-action="Calculate" class="btn btn-primary btn-lg">
                            Розрахувати меню
                        </button>

                        <button type="submit" asp-action="Save" class="btn btn-success btn-lg">
                            Зберегти план і список покупок
                        </button>

                        <button type="submit" asp-action="ExportText" class="btn btn-outline-primary btn-lg">
                            Експорт .txt
                        </button>

                        <button type="submit" asp-action="ExportExcel" class="btn btn-outline-success btn-lg">
                            Експорт .xlsx
                        </button>
                    </div>
                </div>

                <div class="card mt-4">
                    <div class="card-body">
                        <div class="section-header mb-3">
                            <h3 class="mb-0">Імпорт Excel</h3>
                            <span class="planner-section-note">Завантаж файл .xlsx зі списком покупок</span>
                        </div>

                        <div class="row g-3 align-items-end">
                            <div class="col-md-8">
                                <label class="form-label">Excel-файл</label>
                                <input type="file" name="excelFile" class="form-control" accept=".xlsx" />
                            </div>
                            <div class="col-md-4">
                                <button type="submit" asp-action="ImportExcel" class="btn btn-outline-secondary w-100">
                                    Імпорт .xlsx
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.ImportedExcelItems.Any())
    {
        <div class="card mb-4">
            <div class="card-body">
                <div class="section-header mb-3">
                    <h2 class="mb-0">Імпортований список покупок</h2>
                    <span class="planner-section-note">@Model.ImportedExcelFileName</span>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>№</th>
                                <th>Продукт</th>
                                <th>Кількість</th>
                                <th>Одиниця</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.ImportedExcelItems)
                        {
                            <tr>
                                <td>@item.RowNo</td>
                                <td>@item.FoodName</td>
                                <td>@item.QuantityValue</td>
                                <td>@item.UnitName</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.HasResult)
    {
        <div class="planner-summary-wrap mb-4">
            <div class="planner-result-summary-grid">
                <div class="planner-result-summary-card planner-result-summary-card-protein">
                    <div class="planner-result-summary-title">Білки</div>
                    <div class="planner-result-summary-value">@Model.ActualProtein / @Model.ProteinTarget</div>
                </div>

                <div class="planner-result-summary-card planner-result-summary-card-fat">
                    <div class="planner-result-summary-title">Жири</div>
                    <div class="planner-result-summary-value">@Model.ActualFat / @Model.FatTarget</div>
                </div>

                <div class="planner-result-summary-card planner-result-summary-card-carb">
                    <div class="planner-result-summary-title">Вуглеводи</div>
                    <div class="planner-result-summary-value">@Model.ActualCarb / @Model.CarbTarget</div>
                </div>

                <div class="planner-result-summary-card">
                    <div class="planner-result-summary-title">Калорії</div>
                    <div class="planner-result-summary-value">@Model.ActualKcal</div>
                </div>
            </div>
        </div>

        <div class="section-header mb-3">
            <h2 class="mb-0">Готове меню</h2>
            <span class="planner-section-note">На 1 день</span>
        </div>

        <div class="row g-4">
            @foreach (var meal in Model.ResultMeals)
            {
                <div class="col-lg-6">
                    <div class="card planner-result-card h-100">
                        <div class="card-body">
                            <div class="section-header">
                                <h3 class="mb-0">@meal.MealName</h3>
                                <span class="status-badge status-blue">Прийом @meal.MealNo</span>
                            </div>

                            <ul class="planner-result-list mt-3">
                                @foreach (var item in meal.Items)
                                {
                                    <li>
                                        <div>
                                            <strong>@item.Emoji @item.FoodName</strong>: @item.DisplayQuantityValue @item.DisplayUnitName
                                            <div class="data-note">
                                                @item.RoleName · Б @item.Protein / Ж @item.Fat / В @item.Carb / @item.Kcal ккал
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(item.Note))
                                            {
                                                <div class="text-danger mt-1">@item.Note</div>
                                            }
                                        </div>
                                    </li>
                                }
                            </ul>

                            <div class="planner-totals mt-3">
                                Разом: Б @meal.ProteinTotal / Ж @meal.FatTotal / В @meal.CarbTotal / @meal.KcalTotal ккал
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="section-header mt-5 mb-3">
            <h2 class="mb-0">Візуалізація результату</h2>
            <span class="planner-section-note">Аналіз поточного розрахованого меню</span>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="mb-2">Розподіл калорій по прийомах їжі</h3>
                        <p class="page-subtitle mb-3">
                            Дає змогу побачити, чи не перевантажений якийсь окремий прийом їжі
                            та наскільки рівномірно розподілені калорії протягом дня.
                        </p>
                        <div id="mealKcalChart" style="width: 100%; min-height: 360px;"></div>
                    </div>
                </div>
            </div>

            <div class="col-xl-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="mb-2">Розподіл БЖВ по прийомах їжі</h3>
                        <p class="page-subtitle mb-3">
                            Допомагає оцінити баланс білків, жирів і вуглеводів у кожному прийомі їжі
                            та швидко знайти перекіс у меню.
                        </p>
                        <div id="mealMacrosChart" style="width: 100%; min-height: 360px;"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="section-header mt-5 mb-3">
            <h2 class="mb-0">Список покупок</h2>
            <span class="planner-section-note">На @Model.Days дн.</span>
        </div>

        <div class="card planner-shopping-card">
            <div class="card-body">
                @if (Model.ShoppingItems.Any())
                {
                    <div class="planner-shopping-list">
                        @foreach (var item in Model.ShoppingItems)
                        {
                            <div class="planner-shopping-row">
                                <div class="planner-shopping-name">@item.Emoji @item.FoodName</div>
                                <div class="planner-shopping-qty">@decimal.Round(item.DisplayQuantityValue, 0) @item.DisplayUnitName</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="empty-state">Список покупок поки що порожній.</p>
                }
            </div>
        </div>

        <div class="card planner-export-card mt-4">
            <div class="card-body">
                <div class="section-header mb-3">
                    <h3 class="mb-0">Експорт</h3>
                    <button type="button" class="btn btn-outline-primary" id="copyExportBtn">Копіювати текст</button>
                </div>

                <textarea id="plannerExportText" class="form-control planner-export-textarea" readonly>@Model.ExportText</textarea>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="proteinPickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content planner-modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Обери білковий продукт</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <button type="button" class="planner-modal-clear-btn" data-picker-clear="protein">Очистити вибір</button>

                <div class="planner-modal-list">
                    @foreach (var food in Model.ProteinFoods)
                    {
                        <button type="button"
                                class="planner-modal-item"
                                data-picker-select="protein"
                                data-food-id="@food.Id"
                                data-food-label="@($"{food.Emoji} {food.Name}")">
                            <div class="planner-modal-item-name">@food.Emoji @food.Name</div>
                            <div class="planner-modal-item-meta">
                                Б @food.ProteinPer100 / Ж @food.FatPer100 / В @food.CarbPer100
                            </div>
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="carbPickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content planner-modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Обери вуглеводний продукт</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <button type="button" class="planner-modal-clear-btn" data-picker-clear="carb">Очистити вибір</button>

                <div class="planner-modal-list">
                    @foreach (var food in Model.CarbFoods)
                    {
                        <button type="button"
                                class="planner-modal-item"
                                data-picker-select="carb"
                                data-food-id="@food.Id"
                                data-food-label="@($"{food.Emoji} {food.Name}")">
                            <div class="planner-modal-item-name">@food.Emoji @food.Name</div>
                            <div class="planner-modal-item-meta">
                                Б @food.ProteinPer100 / Ж @food.FatPer100 / В @food.CarbPer100
                            </div>
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="fatPickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content planner-modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Обери жировий продукт</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <button type="button" class="planner-modal-clear-btn" data-picker-clear="fat">Очистити вибір</button>

                <div class="planner-modal-list">
                    @foreach (var food in Model.FatFoods)
                    {
                        <button type="button"
                                class="planner-modal-item"
                                data-picker-select="fat"
                                data-food-id="@food.Id"
                                data-food-label="@($"{food.Emoji} {food.Name}")">
                            <div class="planner-modal-item-name">@food.Emoji @food.Name</div>
                            <div class="planner-modal-item-meta">
                                Б @food.ProteinPer100 / Ж @food.FatPer100 / В @food.CarbPer100
                            </div>
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://www.gstatic.com/charts/loader.js"></script>

    <script>
        const resultMeals = @Html.Raw(JsonSerializer.Serialize(Model.ResultMeals));

        google.charts.load('current', { packages: ['corechart', 'bar'] });
        google.charts.setOnLoadCallback(drawPlannerCharts);
        window.addEventListener('resize', drawPlannerCharts);

        function drawPlannerCharts() {
            drawMealKcalChart();
            drawMealMacrosChart();
        }

        function drawMealKcalChart() {
            const container = document.getElementById('mealKcalChart');
            if (!container) return;

            if (!resultMeals || !resultMeals.length) {
                container.innerHTML = '<p class="empty-state">Недостатньо даних для побудови діаграми.</p>';
                return;
            }

            const data = new google.visualization.DataTable();
            data.addColumn('string', 'Прийом їжі');
            data.addColumn('number', 'Калорії');

            resultMeals.forEach(meal => {
                data.addRow([meal.MealName, Number(meal.KcalTotal)]);
            });

            const options = {
                legend: { position: 'none' },
                chartArea: { width: '75%', height: '70%' },
                hAxis: { title: 'Прийом їжі' },
                vAxis: { title: 'Ккал', minValue: 0 }
            };

            const chart = new google.visualization.ColumnChart(container);
            chart.draw(data, options);
        }

        function drawMealMacrosChart() {
            const container = document.getElementById('mealMacrosChart');
            if (!container) return;

            if (!resultMeals || !resultMeals.length) {
                container.innerHTML = '<p class="empty-state">Недостатньо даних для побудови діаграми.</p>';
                return;
            }

            const data = new google.visualization.DataTable();
            data.addColumn('string', 'Прийом їжі');
            data.addColumn('number', 'Білки');
            data.addColumn('number', 'Жири');
            data.addColumn('number', 'Вуглеводи');

            resultMeals.forEach(meal => {
                data.addRow([
                    meal.MealName,
                    Number(meal.ProteinTotal),
                    Number(meal.FatTotal),
                    Number(meal.CarbTotal)
                ]);
            });

            const options = {
                chartArea: { width: '70%', height: '70%' },
                hAxis: { title: 'Прийом їжі' },
                vAxis: { title: 'Грами', minValue: 0 },
                legend: { position: 'top' },
                isStacked: false
            };

            const chart = new google.visualization.ColumnChart(container);
            chart.draw(data, options);
        }
    </script>
}