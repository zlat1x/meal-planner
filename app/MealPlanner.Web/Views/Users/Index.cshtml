@model IEnumerable<MealPlanner.Domain.Entities.User>

@{
    ViewData["Title"] = "Користувачі";
    var items = Model.ToList();
}

<div class="page-hero">
    <div class="page-title-wrap">
        <h1>Користувачі</h1>
        <p class="page-subtitle">Керування користувачами системи Meal Planner.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Додати користувача</a>
    </div>
</div>

<div class="summary-grid">
    <div class="summary-card">
        <div class="summary-card-title">Усього користувачів</div>
        <div class="summary-card-value">@items.Count</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Останнє додавання</div>
        <div class="summary-card-value">@(items.Any() ? items.Max(x => x.CreatedAt).ToString("dd.MM") : "-")</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Унікальних email</div>
        <div class="summary-card-value">@items.Select(x => x.Email).Distinct().Count()</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Активна база</div>
        <div class="summary-card-value">Так</div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (items.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Ім’я</th>
                            <th>Email</th>
                            <th>Створено</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Email</td>
                            <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Деталі</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="empty-state">Користувачів ще немає.</p>
        }
    </div>
</div>