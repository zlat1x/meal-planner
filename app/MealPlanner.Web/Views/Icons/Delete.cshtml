@model MealPlanner.Domain.Entities.Icon

@{
    ViewData["Title"] = "Delete icon";
}

<h1>Delete icon</h1>

<h3>Are you sure you want to delete this icon?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Code</dt>
        <dd class="col-sm-10">@Model.Code</dd>

        <dt class="col-sm-2">Emoji</dt>
        <dd class="col-sm-10">@Model.Emoji</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to list</a>
    </form>
</div>