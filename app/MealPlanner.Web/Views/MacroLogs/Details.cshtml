@model MealPlanner.Domain.Entities.MacroLog

@{
    ViewData["Title"] = "Macro log details";
}

<h1>Macro log details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">User</dt>
        <dd class="col-sm-10">@Model.User.Name</dd>

        <dt class="col-sm-2">Macro</dt>
        <dd class="col-sm-10">@(Model.Macro != null ? Model.Macro.Mode : "-")</dd>

        <dt class="col-sm-2">Event</dt>
        <dd class="col-sm-10">@Model.Event</dd>

        <dt class="col-sm-2">Protein</dt>
        <dd class="col-sm-10">@Model.ProteinG</dd>

        <dt class="col-sm-2">Carbs</dt>
        <dd class="col-sm-10">@Model.CarbsG</dd>

        <dt class="col-sm-2">Fat</dt>
        <dd class="col-sm-10">@Model.FatG</dd>

        <dt class="col-sm-2">Changed at</dt>
        <dd class="col-sm-10">@Model.ChangedAt</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</div>