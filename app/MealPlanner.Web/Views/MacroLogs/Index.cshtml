@model IEnumerable<MealPlanner.Domain.Entities.MacroLog>

@{
    ViewData["Title"] = "Журнал змін макросів";
    var items = Model.ToList();
}

<div class="page-hero">
    <div class="page-title-wrap">
        <h1>Журнал змін макросів</h1>
        <p class="page-subtitle">Історія змін цілей БЖВ у системі.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Додати запис</a>
    </div>
</div>

<div class="summary-grid">
    <div class="summary-card">
        <div class="summary-card-title">Усього записів</div>
        <div class="summary-card-value">@items.Count</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Користувачів</div>
        <div class="summary-card-value">@items.Select(x => x.UserId).Distinct().Count()</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Із макросом</div>
        <div class="summary-card-value">@items.Count(x => x.MacroId.HasValue)</div>
    </div>
    <div class="summary-card">
        <div class="summary-card-title">Остання зміна</div>
        <div class="summary-card-value">@(items.Any() ? items.Max(x => x.ChangedAt).ToString("dd.MM") : "-")</div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (items.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Користувач</th>
                            <th>Подія</th>
                            <th>Макрос</th>
                            <th>Білки</th>
                            <th>Вуглеводи</th>
                            <th>Жири</th>
                            <th>Змінено</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>@item.User.Name</td>
                            <td>@item.Event</td>
                            <td>@(item.Macro?.Mode ?? "—")</td>
                            <td>@item.ProteinG</td>
                            <td>@item.CarbsG</td>
                            <td>@item.FatG</td>
                            <td>@item.ChangedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Деталі</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="empty-state">Записів журналу ще немає.</p>
        }
    </div>
</div>