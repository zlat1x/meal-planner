@model MealPlanner.Domain.Entities.Export

@{
    ViewData["Title"] = "Додати експорт";
}

<h1>Додати експорт</h1>
<p class="page-subtitle mb-4">Збереження інформації про експортований файл.</p>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="UserId" class="form-label">Користувач</label>
                <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId"></select>
            </div>

            <div class="mb-3">
                <label asp-for="PlanId" class="form-label">План</label>
                <select asp-for="PlanId" class="form-select" asp-items="ViewBag.PlanId">
                    <option value="">Не вибрано</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="ListId" class="form-label">Список покупок</label>
                <select asp-for="ListId" class="form-select" asp-items="ViewBag.ListId">
                    <option value="">Не вибрано</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Type" class="form-label">Тип</label>
                <input asp-for="Type" class="form-control" placeholder="Наприклад: PDF" />
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="FileUrl" class="form-label">Шлях до файлу</label>
                <input asp-for="FileUrl" class="form-control" />
                <span asp-validation-for="FileUrl" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-primary">Зберегти</button>
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}