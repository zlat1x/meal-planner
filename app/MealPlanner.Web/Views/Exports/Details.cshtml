@model MealPlanner.Domain.Entities.Export

@{
    ViewData["Title"] = "Деталі експорту";
}

<h1>Деталі експорту</h1>
<p class="page-subtitle mb-4">Інформація про збережений експорт.</p>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Користувач</dt>
            <dd class="col-sm-9">@Model.User.Name</dd>

            <dt class="col-sm-3">Тип</dt>
            <dd class="col-sm-9">@Model.Type</dd>

            <dt class="col-sm-3">План</dt>
            <dd class="col-sm-9">@(Model.Plan?.Status ?? "Не вказано")</dd>

            <dt class="col-sm-3">Список покупок</dt>
            <dd class="col-sm-9">@(Model.List is null ? "Не вказано" : $"На {Model.List.Days} днів")</dd>

            <dt class="col-sm-3">Файл</dt>
            <dd class="col-sm-9 text-break">@Model.FileUrl</dd>

            <dt class="col-sm-3">Створено</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
        </dl>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редагувати</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>