@model MealPlanner.Domain.Entities.Export

@{
    ViewData["Title"] = "Видалити експорт";
}

<h1>Видалити експорт</h1>
<p class="page-subtitle mb-4 text-danger">Підтвердь видалення запису про експорт.</p>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Користувач</dt>
            <dd class="col-sm-9">@Model.User.Name</dd>

            <dt class="col-sm-3">Тип</dt>
            <dd class="col-sm-9">@Model.Type</dd>

            <dt class="col-sm-3">Файл</dt>
            <dd class="col-sm-9 text-break">@Model.FileUrl</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-danger">Видалити</button>
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>