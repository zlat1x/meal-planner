@model MealPlanner.Domain.Entities.Profile

@{
    ViewData["Title"] = "Delete profile";
}

<h1>Delete profile</h1>

<h3>Are you sure you want to delete this profile?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">User</dt>
        <dd class="col-sm-10">@Model.User.Name</dd>

        <dt class="col-sm-2">Weight</dt>
        <dd class="col-sm-10">@Model.WeightKg</dd>

        <dt class="col-sm-2">Goal</dt>
        <dd class="col-sm-10">@Model.Goal</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to list</a>
    </form>
</div>