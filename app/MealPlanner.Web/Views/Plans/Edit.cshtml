@model MealPlanner.Domain.Entities.Plan

@{
    ViewData["Title"] = "Редагувати план";
}

<h1>Редагувати план харчування</h1>
<p class="page-subtitle mb-4">Оновлення параметрів плану.</p>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="UserId" class="form-label">Користувач</label>
                <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId"></select>
            </div>

            <div class="mb-3">
                <label asp-for="MacroId" class="form-label">Макрос</label>
                <select asp-for="MacroId" class="form-select" asp-items="ViewBag.MacroId">
                    <option value="">Не вибрано</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Days" class="form-label">Кількість днів</label>
                <input asp-for="Days" class="form-control" />
            </div>

            <div class="mb-4">
                <label asp-for="Status" class="form-label">Статус</label>
                <input asp-for="Status" class="form-control" />
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-primary">Зберегти зміни</button>
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}