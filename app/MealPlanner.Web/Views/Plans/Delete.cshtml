@model MealPlanner.Domain.Entities.Plan

@{
    ViewData["Title"] = "Видалити план";
}

<h1>Видалити план харчування</h1>
<p class="page-subtitle mb-4 text-danger">
    Підтвердь видалення плану.
</p>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Користувач</dt>
            <dd class="col-sm-9">@Model.User.Name</dd>

            <dt class="col-sm-3">Статус</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Днів</dt>
            <dd class="col-sm-9">@Model.Days</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-danger">Видалити</button>
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>