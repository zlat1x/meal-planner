@model MealPlanner.Domain.Entities.Macro

@{
    ViewData["Title"] = "Macro details";
}

<h1>Macro details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">User</dt>
        <dd class="col-sm-10">@Model.User.Name</dd>

        <dt class="col-sm-2">Protein</dt>
        <dd class="col-sm-10">@Model.ProteinG</dd>

        <dt class="col-sm-2">Carbs</dt>
        <dd class="col-sm-10">@Model.CarbsG</dd>

        <dt class="col-sm-2">Fat</dt>
        <dd class="col-sm-10">@Model.FatG</dd>

        <dt class="col-sm-2">Mode</dt>
        <dd class="col-sm-10">@Model.Mode</dd>

        <dt class="col-sm-2">Created at</dt>
        <dd class="col-sm-10">@Model.CreatedAt</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</div>