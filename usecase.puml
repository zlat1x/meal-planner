@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Користувач" as User
actor "Адміністратор" as Admin
actor "Зовнішній клієнт\n(JavaScript / mobile app)" as Client

rectangle "Meal Planner Web API" {
  usecase "Переглянути продукти" as UC1
  usecase "Шукати продукт\nза назвою або категорією" as UC2
  usecase "Додати власний продукт" as UC3
  usecase "Редагувати власний продукт" as UC4
  usecase "Видалити власний продукт" as UC5
  usecase "Отримати плани харчування" as UC6
  usecase "Отримати деталі плану" as UC7
  usecase "Розрахувати меню\nчерез API" as UC8
  usecase "Отримати список покупок" as UC9
  usecase "Переглянути користувачів" as UC10
  usecase "Керувати продуктами системи" as UC11
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9

Admin --> UC1
Admin --> UC2
Admin --> UC10
Admin --> UC11

Client --> UC1
Client --> UC2
Client --> UC8
Client --> UC9

UC2 .> UC1 : <<extend>>
UC7 .> UC6 : <<extend>>
UC8 .> UC1 : <<include>>
UC9 .> UC6 : <<include>>
@enduml